{
  "entities": {
    "WeeklySchedule": {
      "title": "Weekly Schedule",
      "description": "Represents the staffing schedule for a full week.",
      "type": "object",
      "properties": {
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "hours": {
                "type": "array",
                "items": { "type": "integer" }
              }
            },
            "required": ["day", "hours"]
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["data", "updatedAt"]
    }
  },
  "firestore": {
    "/schedules/weekly": {
      "schema": "WeeklySchedule",
      "description": "The main weekly staffing schedule."
    }
  }
}
