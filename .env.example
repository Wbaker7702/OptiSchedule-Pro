PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Frontend Gemini API key (exposed in the browser by Vite)
# Get from: https://ai.google.dev
VITE_GEMINI_API_KEY=your-google-genai-api-key-here

# Cookie security secret (min 32 chars in production)
COOKIE_SECRET=dev-secret-change-in-production-to-random-32-char-string

# Backend Google GenAI API key (server only)
# Get from: https://ai.google.dev
GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here
