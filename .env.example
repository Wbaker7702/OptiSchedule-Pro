PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Cookie security secret (min 32 chars in production)
COOKIE_SECRET=dev-secret-change-in-production-to-random-32-char-string

# Google GenAI API Key
# Get from: https://ai.google.dev
GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here

# Client-side demo key for legacy AI forecast/insight widgets only.
# Production deployments should proxy all model calls through backend endpoints.
VITE_GEMINI_API_KEY=your-client-demo-gemini-api-key-here
